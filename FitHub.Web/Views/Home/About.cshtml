@{
    ViewData["Title"] = "About FitHub";
}

<div class="container py-2 animate__animated animate__fadeInUp">

    @* --- HEADER SECTION --- *@
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold text-white mb-0">
            FIT<span class="text-danger">HUB</span>
        </h1>
        <h3 class="fw-light text-white-50 border-bottom border-danger d-inline-block pb-1 px-4 text-uppercase tracking-wider">
            Warrior Management System v1.0
        </h3>
    </div>

    <div class="row gx-4 gy-4 align-items-stretch">

        @* --- MISSION & VISION COLUMN --- *@
        <div class="col-lg-7">
            <div class="card h-100 border-0 shadow-lg bg-glass-dark" style="border-radius: 15px;">
                <div class="card-body p-5">

                    @* Mission *@
                    <div class="d-flex mb-4">
                        <div class="me-3">
                            <div class="p-3 rounded-circle bg-dark border border-danger">
                                <i class="bi bi-shield-shaded text-danger fs-3"></i>
                            </div>
                        </div>
                        <div>
                            <h4 class="fw-bold text-white">Our Mission</h4>
                            <p class="text-silver small mb-0" style="line-height: 1.6;">
                                FitHub is engineered to transform traditional gym management into a high-performance digital ecosystem.
                                We eliminate the friction of scheduling, member tracking, and booking collisions, providing a seamless 
                                "Warrior Journey" for both staff and athletes.
                            </p>
                        </div>
                    </div>

                    @* Vision *@
                    <div class="d-flex mb-5">
                        <div class="me-3">
                            <div class="p-3 rounded-circle bg-dark border border-info">
                                <i class="bi bi-cpu-fill text-info fs-3"></i>
                            </div>
                        </div>
                        <div>
                            <h4 class="fw-bold text-white">Our Vision</h4>
                            <p class="text-silver small mb-0" style="line-height: 1.6;">
                                Leveraging the raw power of <strong>.NET 10</strong> and SQL Server, we aim to set the gold standard
                                in fitness software, where data-driven decisions ensure the growth and retention of every member.
                            </p>
                        </div>
                    </div>

                    @* Technologies Badge Cloud *@
                    <h5 class="text-white fw-bold mb-3 border-top border-secondary pt-4 opacity-75">
                        Core Tech Stack:
                    </h5>

                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge rounded-2 px-3 py-2 bg-dark border border-primary text-primary">
                            <i class="bi bi-dot"></i> .NET 10
                        </span>
                        <span class="badge rounded-2 px-3 py-2 bg-dark border border-danger text-danger">
                            ASP.NET Core MVC
                        </span>
                        <span class="badge rounded-2 px-3 py-2 bg-dark border border-secondary text-silver">
                            SQL Server 2022
                        </span>
                        <span class="badge rounded-2 px-3 py-2 bg-dark border border-info text-info">
                            Entity Framework Core
                        </span>
                        <span class="badge rounded-2 px-3 py-2 bg-dark border border-warning text-warning">
                            Bootstrap 5.3
                        </span>
                        <span class="badge rounded-2 px-3 py-2 bg-dark border border-success text-success">
                            Fetch API (AJAX)
                        </span>
                        <span class="badge rounded-2 px-3 py-2 bg-dark border border-danger text-white-50">
                            SweetAlert2
                        </span>
                        <span class="badge rounded-2 px-3 py-2 bg-dark border border-white text-white">
                            Visual Studio 2026
                        </span>
                    </div>

                </div>
            </div>
        </div>

        @* --- DEVELOPER TEAM COLUMN --- *@
        <div class="col-lg-5">
            <div class="card h-100 border-0 shadow-lg bg-glass-dark" style="border-radius: 15px;">
                <div class="card-body p-5 text-center d-flex flex-column justify-content-center">

                    @* Team Initials Emblem *@
                    <div class="mx-auto mb-4 d-flex align-items-center justify-content-center rounded-circle shadow-neon-sm"
                         style="width: 130px; height: 130px; background-color: #1a1a1a; border: 3px solid #dc3545;">
                        <div class="text-white fw-black line-height-1">
                            <span style="font-size: 2.2rem;">EB</span>
                            <span class="text-danger" style="font-size: 1.5rem;">&</span>
                            <span style="font-size: 2.2rem;">MK</span>
                        </div>
                    </div>

                    @* Names Section *@
                    <div class="mb-4">
                        <h3 class="fw-bold text-white mb-0">Emilio Antonio Barrera</h3>
                        <h3 class="fw-bold text-white mt-0">Mehakdeep Kaur</h3>
                    </div>

                    <p class="text-danger fw-bold text-uppercase small tracking-widest mb-2">
                        Full-Stack Software Developers Team
                    </p>
                    <p class="text-silver small mb-4">London Metropolitan University</p>

                    <hr class="border-secondary opacity-25 w-75 mx-auto mb-4">

                    <div class="d-grid gap-3 mb-4">
                        <div class="btn py-2 rounded-2 border border-danger text-danger bg-dark bg-opacity-50 cursor-default fw-bold">
                            <i class="bi bi-people-fill me-2"></i> PARTNERSHIP PROJECT
                        </div>
                        <div class="btn py-2 rounded-2 border border-secondary text-info bg-dark bg-opacity-50 cursor-default">
                            <i class="bi bi-mortarboard-fill me-2"></i> Student ID: 22047055 & Co.
                        </div>
                    </div>

                    <div class="mt-auto pt-3 border-top border-secondary border-opacity-10">
                        <p class="mb-1 text-white small fw-bold text-uppercase">Coursework (CS6004)</p>
                        <p class="mb-1 text-silver small">Academic Year 2025–2026</p>
                        <p class="mb-0 text-danger small fw-black text-uppercase">London - United Kingdom</p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>