@{
    ViewData["Title"] = "System Error";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="text-center p-5 bg-glass-dark border border-danger" style="border-radius: 30px; max-width: 600px;">
        
        <div class="mb-4">
            <i class="bi @ViewData["ErrorIcon"] text-danger" style="font-size: 7rem;"></i>
        </div>

        <h1 class="display-3 fw-black text-white mb-0 text-uppercase">System <span class="text-danger">Error</span></h1>
        <div class="h5 text-silver fw-bold mb-4 tracking-widest text-uppercase">@ViewData["ErrorMessage"]</div>
        
        <p class="text-silver mb-5 fs-5">
            Warrior, the requested coordinates are invalid or the sector is under maintenance.
            Please return to the main command center.
        </p>

        <a asp-controller="Home" asp-action="Index" class="btn btn-fithub btn-lg px-5 shadow-neon-sm fw-black">
            <i class="bi bi-house-door-fill me-2"></i> RETURN TO HOME
        </a>
    </div>
</div>