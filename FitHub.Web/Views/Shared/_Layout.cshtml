<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitHub</title>
    
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light navbar-modern sticky-top mb-3">
            <div class="container">
                 
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-heart-pulse-fill me-2 text-white" style="font-size: 1.6rem;"></i>
                    <span class="fw-bolder" style="letter-spacing: -0.5px;">FITHUB</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark d-flex align-items-center" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1 text-primary"></i> Home
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Manager")))
                        {
                            // User Security Management 
                            <li class="nav-item">
                                <a class="nav-link text-dark d-flex align-items-center" asp-controller="Users" asp-action="Index">
                                    <i class="bi bi-shield-lock me-1 text-info"></i> Users
                                </a>
                            </li>

                            // Class Categories Management
                            <li class="nav-item">
                                <a class="nav-link text-dark d-flex align-items-center" asp-controller="Categories" asp-action="Index">
                                    <i class="bi bi-bookmark-heart text-success"></i> Categories
                                </a>
                            </li>

                             // Staff / Instructor Management 
                            <li class="nav-item">
                                <a class="nav-link text-dark d-flex align-items-center" asp-controller="Instructors" asp-action="Index">
                                    <i class="bi bi-person-badge me-1 text-succces"></i> Staff
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark d-flex align-items-center" asp-controller="FitnessClasses" asp-action="Index">
                                    <i class="bi bi-calendar-event text-warning me-2"></i> Classes
                                </a>
                            </li>
                            
                        }

                        <li class="nav-item">
                            <a class="nav-link text-dark d-flex align-items-center" asp-controller="Home" asp-action="Pricing">
                                <i class="bi bi-tags me-1"></i> Plans
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark d-flex align-items-center" asp-controller="Home" asp-action="About">
                                <i class="bi bi-info-circle text-info me-1"></i> About
                            </a>
                        </li>

                        <div class="ms-auto d-flex align-items-center">
                            <partial name="_LoginPartial" />
                        </div>

                    </ul>
                    
                    
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

   
    <footer class="footer-modern py-4 mt-5">
        <div class="container text-center">
            <div class="footer-content">
                <span class="text-silver small">
                    &copy; 2026 London -
                    <i class="bi bi-heart-pulse-fill text-danger mx-1"></i>
                    <strong>FitHub</strong> -
                    <i class="bi bi-code-slash mx-1 text-primary"></i>
                    By Emilio Barrera & Mehakdeep Kaur
                    <i class="bi bi-heart-fill ms-1 animate-pulse" style="color: #ff3b3b;"></i>
                </span>
            </div>
        </div>
    </footer>
    
   
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

   
    @if (TempData["Success"] != null)
    {
        <script>showSuccess('@TempData["Success"]');</script>
    }
    @if (TempData["Error"] != null)
    {
        <script>showError('@TempData["Error"]');</script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>