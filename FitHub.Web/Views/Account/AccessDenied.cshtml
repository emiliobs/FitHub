@{
    ViewData["Title"] = "Access Denied";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="text-center p-5 bg-glass-dark border border-danger shadow-neon-lg animate__animated animate__zoomIn" style="border-radius: 30px; max-width: 600px;">
        
        <div class="mb-4">
            <i class="bi bi-shield-slash text-danger animate__animated animate__pulse animate__infinite" style="font-size: 7rem;"></i>
        </div>

        <h1 class="display-3 fw-black text-white mb-0 text-uppercase">Access <span class="text-danger">Denied</span></h1>
        <div class="h5 text-silver fw-bold mb-4 tracking-widest text-uppercase">Unauthorized Entry Detected</div>
        
        <p class="text-silver mb-5 fs-5">
            Warrior, your current <span class="text-white fw-bold">Clearance Level</span> is not sufficient to enter this sector.
        </p>

        <a asp-controller="Home" asp-action="Index" class="btn btn-fithub btn-lg px-5 shadow-neon-sm fw-black">
            <i class="bi bi-house-door-fill me-2"></i> RETURN TO HOME
        </a>
    </div>
</div>

<style>
    .shadow-neon-lg { box-shadow: 0 0 40px rgba(255, 59, 59, 0.2); }
    .fw-black { font-weight: 900; }
</style>