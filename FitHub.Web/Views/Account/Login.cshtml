@model FitHub.Web.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login - FitHub Energy";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 77vh;">
    <div class="col-md-5">
        <div class="text-center mb-4 animate__animated animate__fadeInDown">
            <i class="bi bi-shield-lock-fill text-danger display-1 shadow-neon"></i>
            <h2 class="text-white fw-bold mt-2 text-uppercase">Member Access</h2>
            <p class="text-silver small">Enter your credentials to push your limits</p>
        </div>

        <div class="card shadow-lg p-4 border-0 bg-glass-dark animate__animated animate__fadeInUp">
            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label text-silver small fw-bold text-uppercase">Email Address</label>
                    <input asp-for="Email" class="form-control fithub-input-sm" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Password" class="form-label text-silver small fw-bold text-uppercase">Password</label>
                    <input asp-for="Password" type="password" class="form-control fithub-input-sm" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input bg-dark border-danger" />
                    <label asp-for="RememberMe" class="form-check-label text-silver small">Remember my session</label>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-fithub py-2 fw-bold">
                        <i class="bi bi-box-arrow-in-right me-2"></i> SIGN IN
                    </button>
                    <a asp-action="Register" class="btn btn-outline-secondary border-0 text-silver mt-2 small">
                        Don't have an account? <span class="text-danger fw-bold">Register here</span>
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>