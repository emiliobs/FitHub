@using FitHub.Web.Models.Domain
@model FitHub.Web.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile - FitHub";
}

<div class="container mt-5 py-5 animate__animated animate__fadeIn" style="min-height: 70vh;">
    <div class="row justify-content-center">
        <div class="col-md-9">
            @* Increased slightly to accommodate the status card *@
            <div class="card bg-glass-dark border-0 shadow-lg p-4">
                
                @* --- HEADER --- *@
                <div class="text-center mb-4 border-bottom border-danger pb-3">
                    <h2 class="text-white fw-bold"><i class="bi bi-person-badge text-danger me-2"></i>MY PROFILE</h2>
                    <p class="text-silver small text-uppercase">Manage your personal information and warrior status</p>
                </div>

                @* --- NEW: WARRIOR STATUS DASHBOARD --- *@
                <div class="row mb-4 animate__animated animate__fadeInDown animate__delay-1s">
                    <div class="col-12">
                        <div class="card bg-dark border-danger " style="border-style: dashed;">
                            <div class="card-body d-flex align-items-center justify-content-between flex-wrap">
                                <div class="d-flex align-items-center mb-2 mb-md-0">
                                    <div class="bg-glass-dark rounded-circle p-3 border border-danger me-3">
                                        <i class="bi bi-gem text-danger fs-4 shadow-neon"></i>
                                    </div>
                                    <div>
                                        <h6 class="text-silver small fw-bold mb-0 text-uppercase">Membership Level</h6>
                                        @if (Model.MembershipPlan == SubscriptionType.Warrior)
                                        {
                                            <span class="badge bg-danger shadow-neon text-white p-2 px-3">
                                                <i class="bi bi-shield-fill-check"></i> WARRIOR VIP
                                            </span>
                                        }
                                        else if (Model.MembershipPlan == SubscriptionType.None)
                                        {
                                            <span class="badge border border-silver text-silver p-2 px-3">
                                                PAY PER CLASS
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary shadow-neon-sm text-white p-2 px-3 text-uppercase">
                                                @Model.MembershipPlan Plan
                                            </span>
                                        }
                                    </div>
                                </div>

                                <div class="text-md-end">
                                    @if (Model.SubscriptionEndDate.HasValue && Model.IsActive)
                                    {
                                        <p class="text-silver small mb-0">Subscription valid until:</p>
                                        <h5 class="text-white fw-bold mb-0">@Model.SubscriptionEndDate.Value.ToString("MMM dd, yyyy")</h5>
                                        <small class="text-danger fw-bold">
                                            <i class="bi bi-hourglass-split"></i> @Model.DaysRemaining Days Remaining
                                        </small>
                                    }
                                    else if (Model.MembershipPlan != SubscriptionType.None && !Model.IsActive)
                                    {
                                        <span class="text-warning small fw-bold"><i class="bi bi-exclamation-octagon"></i> PLAN EXPIRED</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-12">
                        <div class="card bg-dark border-secondary">
                            <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
                                <div>
                                    <h6 class="text-white fw-bold mb-1 text-uppercase">Billing & Records</h6>
                                    <p class="text-silver small mb-0">Quick access to your class payments and generated invoices.</p>
                                </div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-controller="Payments" asp-action="History" class="btn btn-outline-light btn-sm">
                                        <i class="bi bi-receipt me-1"></i> Transactions
                                    </a>
                                    <a asp-controller="Payments" asp-action="Invoices" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-file-earmark-text me-1"></i> Invoices
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* --- PROFILE EDIT FORM --- *@
                <form asp-action="MyProfile" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ExistingPhoto" />

                    <div class="row">
                        <div class="col-md-4 text-center mb-4">
                            <label class="text-danger fw-bold small d-block mb-2 text-uppercase">Profile Photo</label>
                            <div class="position-relative d-inline-block">
                                <img id="profile-preview" src="~/images/profiles/@(Model.ExistingPhoto ?? "default-user.png")"
                                     class="rounded-circle border border-danger shadow-neon p-1"
                                     style="width: 150px; height: 150px; object-fit: cover;" />
                                <div class="mt-2">
                                    <label for="PhotoFileInput" class="btn btn-outline-danger btn-sm shadow-neon-sm">
                                        <i class="bi bi-camera"></i> Change Photo
                                    </label>
                                    <input asp-for="PhotoFile" type="file" id="PhotoFileInput" class="d-none" accept="image/*" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-8">
                            <div class="mb-3">
                                <label asp-for="Email" class="text-silver small fw-bold">EMAIL ADDRESS</label>
                                <input asp-for="Email" class="form-control fithub-input-sm bg-dark text-muted" readonly />
                                <small class="text-white italic" style="font-size: 0.75rem;">
                                    <i class="bi bi-info-circle"></i> Email is linked to your identity and cannot be changed.
                                </small>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="FirstName" class="text-silver small fw-bold">FIRST NAME</label>
                                    <input asp-for="FirstName" class="form-control fithub-input-sm" />
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="LastName" class="text-silver small fw-bold">LAST NAME</label>
                                    <input asp-for="LastName" class="form-control fithub-input-sm" />
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn btn-fithub fw-bold py-2 shadow-neon-sm">
                                    <i class="bi bi-save me-1"></i> SAVE CHANGES
                                </button>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary border-0 text-silver mt-2">Cancel</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            $("#PhotoFileInput").change(function() {
                if (this.files && this.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        $('#profile-preview').attr('src', e.target.result);
                    }
                    reader.readAsDataURL(this.files[0]);
                }
            });
        });
    </script>
}