@model IEnumerable<FitHub.Web.Models.Domain.Invoice>

@{
    ViewData["Title"] = "Invoices";
}

<div class="container py-5">
    <h2 class="text-white mb-4">My Invoices</h2>

    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>Invoice</th>
                <th>Issue Date</th>
                <th>Total</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var i in Model)
            {
                <tr>
                    <td>@i.InvoiceNumber</td>
                    <td>@i.IssueDate.ToString("yyyy-MM-dd")</td>
                    <td>@i.TotalAmount.ToString("C")</td>
                    <td>@(i.IsPaid ? "Paid" : "Pending")</td>
                    <td>
                        <a asp-action="ViewInvoice" asp-route-invoiceId="@i.Id" class="btn btn-sm btn-outline-light">View</a>
                        <a asp-action="DownloadInvoice" asp-route-invoiceId="@i.Id" class="btn btn-sm btn-danger">Download</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

