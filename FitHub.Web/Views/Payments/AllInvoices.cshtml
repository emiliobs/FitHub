@model IEnumerable<FitHub.Web.Models.Domain.Invoice>

@{
    ViewData["Title"] = "All Invoices";
}

<div class="container py-5">
    <h2 class="text-white mb-4">All Invoices (Admin)</h2>

    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>Invoice</th>
                <th>User</th>
                <th>Class</th>
                <th>Total</th>
                <th>Status</th>
                <th>Issue Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var i in Model)
            {
                <tr>
                    <td>@i.InvoiceNumber</td>
                    <td>@i.Payment.Subscription.ApplicationUser.Email</td>
                    <td>@i.Payment.Subscription.FitnessClass.Title</td>
                    <td>@i.TotalAmount.ToString("C")</td>
                    <td>@(i.IsPaid ? "Paid" : "Pending")</td>
                    <td>@i.IssueDate.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
</div>


