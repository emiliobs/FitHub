@model IEnumerable<FitHub.Web.Models.Domain.Payment>

@{
    ViewData["Title"] = "Payment History";
}

<div class="container py-5">
    <h2 class="text-white mb-4">Payment History</h2>

    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Class</th>
                <th>Category</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.PaymentDate.ToString("yyyy-MM-dd")</td>
                    <td>@p.Subscription.FitnessClass.Title</td>
                    <td>@p.Subscription.Category.Name</td>
                    <td>@p.Amount.ToString("C")</td>
                    <td>@p.Status</td>
                    <td>
                        <a asp-action="Details" asp-route-paymentId="@p.Id" class="btn btn-sm btn-outline-light">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


