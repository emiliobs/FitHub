@model IEnumerable<FitHub.Web.Models.Domain.Payment>

@{
    ViewData["Title"] = "All Payments";
}

<div class="container py-5">
    <h2 class="text-white mb-4">All Payments (Admin)</h2>

    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>User</th>
                <th>Class</th>
                <th>Transaction</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Subscription.ApplicationUser.Email</td>
                    <td>@p.Subscription.FitnessClass.Title</td>
                    <td>@p.TransactionId</td>
                    <td>@p.Amount.ToString("C")</td>
                    <td>@p.Status</td>
                    <td>@p.PaymentDate.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
</div>


