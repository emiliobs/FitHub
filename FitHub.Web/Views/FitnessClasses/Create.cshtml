@model FitHub.Web.Models.Domain.FitnessClass

@{
    ViewData["Title"] = "Create Fitness Class";
}

<div class="container mt-5" style="min-height: 70vh;">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="d-flex align-items-center mb-4">
                <i class="bi bi-calendar-plus text-danger fs-1 me-3"></i>
                <div>
                    <h2 class="text-white fw-bold mb-0">New Fitness Class</h2>
                    <p class="text-silver small">Schedule a new fitness class</p>
                </div>
            </div>

            <div class="card shadow-lg p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                        <strong>Validation Errors:</strong>
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Create" method="post">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Title" class="form-label text-silver fw-bold small text-uppercase">Class Title</label>
                                <input asp-for="Title" class="form-control fithub-input-sm" placeholder="e.g. Morning Yoga" />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Capacity" class="form-label text-silver fw-bold small text-uppercase">Capacity</label>
                                <input asp-for="Capacity" type="number" class="form-control fithub-input-sm" min="1" max="200" />
                                <span asp-validation-for="Capacity" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="form-label text-silver fw-bold small text-uppercase">Description</label>
                        <textarea asp-for="Description" class="form-control fithub-input-sm" rows="3" placeholder="Optional description"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="ScheduleDate" class="form-label text-silver fw-bold small text-uppercase">Schedule Date & Time</label>
                                <input asp-for="ScheduleDate" type="datetime-local" class="form-control fithub-input-sm" />
                                <span asp-validation-for="ScheduleDate" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Price" class="form-label text-silver fw-bold small text-uppercase">Price ($)</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control fithub-input-sm" min="0" max="500" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="CategoryId" class="form-label text-silver fw-bold small text-uppercase">Category</label>
                                <select asp-for="CategoryId" class="form-select fithub-input-sm" asp-items="ViewBag.CategoryId"></select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="InstructorId" class="form-label text-silver fw-bold small text-uppercase">Instructor</label>
                                <select asp-for="InstructorId" class="form-select fithub-input-sm" asp-items="ViewBag.InstructorId"></select>
                                <span asp-validation-for="InstructorId" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-fithub py-2">
                            <i class="bi bi-save2 me-2"></i> CREATE CLASS
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary border-0 text-silver mt-2">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


