@model FitHub.Web.ViewModels.FitnessClassViewModel

@{
    ViewData["Title"] = "Edit Training Session";
}

<div class="container mt-5 py-4 animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            
            @* --- HEADER --- *@
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-outline-secondary border-0 text-silver me-3">
                    <i class="bi bi-arrow-left fs-4"></i>
                </a>
                <div>
                    <h2 class="text-white fw-bold text-uppercase mb-0">Edit Session</h2>
                    <p class="text-warning small fw-bold mb-0 text-uppercase">Modify Warrior Training Details</p>
                </div>
            </div>

            <div class="card bg-glass-dark border-0 shadow-lg p-4">
                <form asp-action="Edit" method="post">
                    @* CRITICAL: Hidden ID for EF tracking *@
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="BrowserTimeZone" id="browserTimeZone" />
                    <input type="hidden" asp-for="BrowserUtcOffsetMinutes" id="browserUtcOffsetMinutes" />

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row">
                        @* --- COLUMN 1: BASIC INFO --- *@
                        <div class="col-md-7 border-end border-secondary border-opacity-25 pe-md-4">
                            <div class="mb-4">
                                <label asp-for="Title" class="text-silver small fw-bold mb-2 text-uppercase">Class Title</label>
                                <input asp-for="Title" class="form-control fithub-input bg-dark text-white border-secondary" />
                                <span asp-validation-for="Title" class="text-danger x-small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Description" class="text-silver small fw-bold mb-2 text-uppercase">Workout Description</label>
                                <textarea asp-for="Description" class="form-control fithub-input bg-dark text-white border-secondary" rows="5"></textarea>
                                <span asp-validation-for="Description" class="text-danger x-small"></span>
                            </div>

                            <div class="row">
                                <div class="col-6 mb-4">
                                    <label asp-for="ScheduleDate" class="text-silver small fw-bold mb-2 text-uppercase">Date & Time</label>
                                    <input asp-for="ScheduleDate" type="datetime-local" id="scheduleDateInput" data-utc="@Model.ScheduleDate.ToString("O")" class="form-control fithub-input bg-dark text-white border-secondary" />
                                    <span asp-validation-for="ScheduleDate" class="text-danger x-small"></span>
                                    <div class="text-silver x-small mt-2">
                                        <div id="browserTimeLabel"></div>
                                        <div id="istTimeLabel"></div>
                                    </div>
                                </div>
                                <div class="col-6 mb-4">
                                    <label asp-for="Price" class="text-silver small fw-bold mb-2 text-uppercase">Access Price ($)</label>
                                    <input asp-for="Price" class="form-control fithub-input bg-dark text-white border-secondary" />
                                    <span asp-validation-for="Price" class="text-danger x-small"></span>
                                </div>
                            </div>
                        </div>

                        @* --- COLUMN 2: ASSIGNMENT --- *@
                        <div class="col-md-5 ps-md-4">
                            <div class="mb-4">
                                <label asp-for="CategoryId" class="text-silver small fw-bold mb-2 text-uppercase">Category</label>
                                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select fithub-input bg-dark text-white border-secondary">
                                    <option value="" disabled>-- Select Category --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger x-small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="InstructorId" class="text-silver small fw-bold mb-2 text-uppercase">Lead Instructor</label>
                                <select asp-for="InstructorId" asp-items="Model.Instructors" class="form-select fithub-input bg-dark text-white border-secondary">
                                    <option value="" disabled>-- Select Instructor --</option>
                                </select>
                                <span asp-validation-for="InstructorId" class="text-danger x-small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Capacity" class="text-silver small fw-bold mb-2 text-uppercase">Warrior Capacity</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-dark border-secondary text-danger"><i class="bi bi-people-fill"></i></span>
                                    <input asp-for="Capacity" class="form-control fithub-input bg-dark text-white border-secondary" />
                                </div>
                                <span asp-validation-for="Capacity" class="text-danger x-small"></span>
                            </div>

                            <div class="d-grid gap-2 mt-5">
                                
                                <button type="submit" class="btn btn-fithub fw-bold py-3 shadow-neon">
                                    <i class="bi bi-pencil-fill me-2"></i> UPDATE SESSION
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary border-0 text-silver mt-2">
                                    Cancel Changes
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const tzField = document.getElementById('browserTimeZone');
            const offsetField = document.getElementById('browserUtcOffsetMinutes');
            const scheduleInput = document.getElementById('scheduleDateInput');
            const localLabel = document.getElementById('browserTimeLabel');
            const istLabel = document.getElementById('istTimeLabel');

            if (tzField) {
                tzField.value = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
            }

            if (offsetField) {
                offsetField.value = String(new Date().getTimezoneOffset());
            }

            const setInputFromUtc = () => {
                if (!scheduleInput) {
                    return;
                }

                const utcText = scheduleInput.dataset.utc;
                if (!utcText) {
                    return;
                }

                const utcDate = new Date(utcText);
                if (Number.isNaN(utcDate.getTime())) {
                    return;
                }

                const local = new Date(utcDate.getTime() - utcDate.getTimezoneOffset() * 60000);
                scheduleInput.value = local.toISOString().slice(0, 16);
            };

            const toDateFromInput = (value) => {
                if (!value) {
                    return null;
                }

                const localDate = new Date(value);
                return Number.isNaN(localDate.getTime()) ? null : localDate;
            };

            const renderLabels = () => {
                if (!scheduleInput || !localLabel || !istLabel) {
                    return;
                }

                const selected = toDateFromInput(scheduleInput.value);
                if (!selected) {
                    localLabel.textContent = '';
                    istLabel.textContent = '';
                    return;
                }

                const browserZone = Intl.DateTimeFormat().resolvedOptions().timeZone || 'Browser Zone';
                const localText = selected.toLocaleString(undefined, {
                    dateStyle: 'medium',
                    timeStyle: 'short'
                });

                const istText = selected.toLocaleString('en-IN', {
                    dateStyle: 'medium',
                    timeStyle: 'short',
                    timeZone: 'Asia/Kolkata'
                });

                localLabel.textContent = `Local (${browserZone}): ${localText}`;
                istLabel.textContent = `IST (Asia/Kolkata): ${istText}`;
            };

            setInputFromUtc();
            scheduleInput?.addEventListener('change', renderLabels);
            renderLabels();
        })();
    </script>
}