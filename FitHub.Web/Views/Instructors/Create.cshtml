@model FitHub.Web.ViewModels.InstructorViewModel

<div class="container mt-5 animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card bg-glass-dark border-danger shadow-lg p-4">
                <h2 class="text-white fw-bold mb-4 border-bottom border-danger pb-2">
                    <i class="bi bi-person-plus text-danger"></i> Add New Instructor
                </h2>

                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label text-silver small fw-bold">FULL NAME</label>
                            <input asp-for="Name" class="form-control fithub-input" placeholder="e.g. John Doe" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Specialty" class="form-label text-silver small fw-bold">SPECIALTY</label>
                            <input asp-for="Specialty" class="form-control fithub-input" placeholder="e.g. Yoga Master" />
                            <span asp-validation-for="Specialty" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label text-silver small fw-bold">EMAIL ADDRESS</label>
                            <input asp-for="Email" class="form-control fithub-input" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label text-silver small fw-bold">PHONE NUMBER</label>
                            <input asp-for="Phone" class="form-control fithub-input" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="PhotoFile" class="form-label text-silver small fw-bold">PROFILE PHOTO</label>
                        <input asp-for="PhotoFile" type="file" class="form-control fithub-input" accept="image/*" />
                    </div>

                    <div class="d-flex justify-content-between pt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                        <button type="submit" class="btn btn-fithub px-5 shadow-neon-sm fw-bold">SAVE INSTRUCTOR</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>