@model IEnumerable<FitHub.Web.Models.Domain.Instructor>

@{
    ViewData["Title"] = "Staff Management";
}

<div class="container mt-5" style="min-height: 70vh;">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold">
            
            <i class="bi bi-person-badge text-danger"></i> Staff Management
        </h2>
        
        <a asp-action="Create" class="btn btn-fithub px-4 shadow-neon-sm">
            <i class="bi bi-plus-circle me-1"></i> Add Instructor
        </a>
    </div>
     
    <div class="card shadow-lg p-4 border-0 bg-glass-dark">
      
        <div class="table-responsive">
           
            <table id="instructorsTable" class="table table-dark table-hover bg-transparent mb-0">
                <thead>
                    <tr class="border-danger">
                        
                        <th class="text-danger fw-black small text-uppercase">Photo</th>
                        <th class="text-danger fw-black small text-uppercase">Name</th>
                        <th class="text-danger fw-black small text-center text-uppercase">Specialty</th>
                        <th class="text-danger fw-black small text-uppercase">Contact</th>
                        <th class="text-center text-danger fw-black small text-uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-silver">
                    
                    @foreach (var item in Model)
                    {
                        // Row with a unique ID to allow JavaScript to find and remove it during Fetch deletion 
                        <tr id="row-@item.Id" class="border-secondary align-middle">
                            <td class="py-3">
                               
                                <img src="~/images/profiles/@item.Photo"
                                     alt="@item.Name"
                                     class="rounded-circle border border-danger shadow-sm"
                                     style="width: 50px; height: 50px; object-fit: cover;" />
                            </td>
                            
                            <td class="fw-bold text-white">@item.Name</td>
                            <td class="text-center">
                                
                                <span class="badge bg-outline-danger border border-danger px-3">
                                    @(item.Category?.Name ?? "General")
                                </span>
                            </td>
                            
                            <td class="small">
                                <i class="bi bi-envelope text-danger"></i> @item.Email<br />
                                <i class="bi bi-telephone text-danger"></i> @item.Phone
                            </td>
                            <td class="text-center">
                               
                                <div class="btn-group">
                                  
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm border-0" title="Edit">
                                        <i class="bi bi-pencil-square fs-5"></i>
                                    </a>

                                    
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm border-0" title="View Profile">
                                        <i class="bi bi-eye fs-5"></i>
                                    </a>

                                   
                                    @Html.AntiForgeryToken()

                                    
                                    <button type="button" class="btn btn-outline-danger btn-sm border-0"
                                            onclick="executeDelete(@item.Id)" title="Delete Instructor">
                                        <i class="bi bi-trash fs-5"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Global variable to store the DataTable instance for easy access
        var table;

        $(document).ready(function () {
            // Initializing the DataTables plugin with specific responsive and language settings
            table = $('#instructorsTable').DataTable({
                "responsive": true,
                "pageLength": 5,
                "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]],
                "language": {
                    "search": "<span class='text-white'>Search:</span>",
                    "lengthMenu": "<span class='text-white'>Show _MENU_ entries</span>",
                    "info": "<span class='text-white small'>Showing _START_ to _END_ of _TOTAL_ entries</span>",
                    "paginate": {
                        "next": "Next",
                        "previous": "Prev"
                    }
                }
            });

            // Applying custom brand CSS classes to DataTables generated inputs
            $('.dataTables_filter input').addClass('form-control fithub-input-sm d-inline-block w-auto ms-2 border-secondary text-white');
            $('.dataTables_length select').addClass('form-select fithub-input-sm d-inline-block w-auto mx-2 bg-dark text-white border-secondary');
        });

        
        // Asynchronous function to handle the deletion of an instructor record
        //param {number} id - The unique identifier of the instructor to delete
        
        async function executeDelete(id) {
            // Triggering the custom SweetAlert confirmation modal
            confirmDelete(async () => {
                try {
                    // Extracting the Antiforgery token for security verification
                    const token = $('input[name="__RequestVerificationToken"]').val();

                    // Sending the DELETE request via POST to the controller endpoint
                    const response = await fetch(`/Instructors/DeleteFetch/${id}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'Content-Type': 'application/x-www-form-urlencoded'
                        }
                    });

                    // Converting the server response to JSON
                    const result = await response.json();

                    // If deletion is successful in the backend, update the UI
                    if (result.success) {
                        const row = document.getElementById(`row-${id}`);
                        // Applying the exit animation from Animate.css
                        row.classList.add('animate__animated', 'animate__fadeOutLeft');

                        // Waiting for animation to complete before removing from DataTables memory
                        setTimeout(() => {
                            table.row($(row)).remove().draw(false);
                            showSuccess(result.message);
                        }, 600);
                    } else {
                        // Showing the error message if something fails on the server
                        showError(result.message);
                    }
                } catch (error) {
                    // General connection failure handling
                    showError("Connection error. Could not reach the server.");
                }
            });
        }
    </script>
}