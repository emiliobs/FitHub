@model FitHub.Web.Models.Domain.Category

@{
    ViewData["Title"] = "Create Category";
}

<div class="container mt-5" style="min-height: 70vh;">
    <div class="row justify-content-center">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
            
                <div class="d-flex align-items-center mb-4">
                    <i class="bi bi-plus-circle-dotted text-danger fs-1 me-3"></i>
                    <div>
                        <h2 class="text-white fw-bold mb-0">New Category</h2>
                        <p class="text-silver small">Add a new fitness category to your system</p>
                    </div>
                </div>

                <div class="card shadow-lg p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-4">
                            <label asp-for="Name" class="form-label text-silver fw-bold small text-uppercase">Category Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-danger border-end-0">
                                    <i class="bi bi-tag text-danger"></i>
                                </span>
                                <input asp-for="Name" class="form-control fithub-input-sm  border-start-0 ps-0"
                                       placeholder="e.g. Crossfit, Yoga, HIIT..." />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-fithub py-2">
                                <i class="bi bi-save2 me-2"></i> CREATE CATEGORY
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary border-0 text-silver mt-2">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </form>
                </div>

            </div>
        </div>

    </div>
   
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}